{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "person.schema.json",
  "type": "object",
  "required": ["id", "name"],
  "properties": {
    "id":  { "type": "string", "format": "uuid" },

    "name": { "$ref": "#/$defs/nameObject" },
    "names": {
      "description": "Additional or alternate name variants (maiden, immigrant, alias, etc.)",
      "type": "array",
      "items": { "$ref": "#/$defs/nameObject" }
    },

    "sex":   { "type": "string", "enum": ["M", "F", "X"] },
    "title": { "type": "string", "description": "Nobility or honorific title (e.g. Sir, Dame, Duke)" },

    "birth":  { "$ref": "#/$defs/lifeEvent" },
    "death":  { "$ref": "#/$defs/lifeEvent" },
    "burial": { "$ref": "#/$defs/lifeEvent" },

    "occupation":           { "type": "array", "items": { "type": "string" } },
    "nationality":          { "type": "string" },
    "religion":             { "type": "string" },
    "caste":                { "type": "string" },
    "physical_description": { "type": "string" },
    "national_id": {
      "type": "object",
      "required": ["value"],
      "properties": {
        "value": { "type": "string" },
        "type":  { "type": "string", "description": "e.g. passport, ssn, nino" }
      },
      "additionalProperties": false
    },
    "facts": {
      "description": "Typed personal facts or characteristics (GEDCOM FACT/EVEN with TYPE)",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "value"],
        "properties": {
          "type":  { "type": "string" },
          "value": { "type": "string" },
          "note":  { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "associations": {
      "description": "Non-family links to other persons (GEDCOM ASSO)",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["person", "relation"],
        "properties": {
          "person":   { "type": "string", "format": "uuid" },
          "relation": { "type": "string", "description": "e.g. godfather, witness, employer" },
          "note":     { "type": "string" },
          "sources":  { "$ref": "#/$defs/sources" }
        },
        "additionalProperties": false
      }
    },

    "avatar_file": { "type": ["string", "null"] },
    "media_files": { "type": "array", "items": { "type": "string" } },
    "notes":       { "type": "array", "items": { "type": "string" } },
    "sources":     { "$ref": "#/$defs/sources" },
    "events":      { "$ref": "#/$defs/events" },
    "uncertain":   { "type": "array", "items": { "type": "string" } },
    "restriction": { "type": "string", "enum": ["confidential", "locked", "privacy"] },
    "changed":     { "type": "string", "description": "ISO 8601 datetime of last change" }
  },

  "$defs": {
    "nameObject": {
      "type": "object",
      "properties": {
        "given":          { "type": "string", "description": "Given name(s)" },
        "surname":        { "type": "string", "description": "Surname(s)" },
        "surname_prefix": { "type": "string", "description": "Surname prefix (van, de, von)" },
        "prefix":         { "type": "string", "description": "Name prefix (Dr., Rev., Sir)" },
        "suffix":         { "type": "string", "description": "Name suffix (Jr., III, Esq.)" },
        "nickname":       { "type": "string", "description": "Nickname, distinct from alias" },
        "alias":          { "type": "string", "description": "Known alias or stage name" },
        "type":           { "type": "string", "description": "Name type: birth, maiden, immigrant, adopted, alias, etc." },
        "phonetic":       { "type": "string", "description": "Phonetic variation of the full name" },
        "romanized":      { "type": "string", "description": "Romanized variation of the full name" },
        "note":           { "type": "string" }
      },
      "additionalProperties": false
    },

    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title":         { "type": "string", "description": "Short description of the source" },
          "type":          { "type": "string", "enum": ["personal-document","photograph","civil-record","church-record","census","oral","gedcom","other"] },
          "file":          { "type": "string", "description": "Path or URL to the source file" },
          "date":          { "type": "string", "description": "Date the source was created or accessed" },
          "recorded_date": { "type": "string", "description": "Date the entry was recorded in the source" },
          "page":          { "type": "string", "description": "Page, folio, or frame reference within the source" },
          "text":          { "type": "string", "description": "Verbatim transcription of relevant text" },
          "quality":       { "type": "integer", "minimum": 0, "maximum": 3, "description": "Certainty: 0 unreliable, 1 questionable, 2 secondary, 3 primary" },
          "event_type":    { "type": "string", "description": "Type of event recorded in this source" },
          "role":          { "type": "string", "description": "Person's role in the cited event (e.g. bride, witness)" },
          "note":          { "type": "string" }
        },
        "additionalProperties": false
      }
    },

    "event": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "immigration", "emigration", "residence", "military", "census", "education",
            "christening", "cremation", "adoption", "baptism", "bar_mitzvah", "bat_mitzvah",
            "blessing", "adult_christening", "confirmation", "first_communion", "ordination",
            "naturalization", "probate", "will", "graduation", "retirement",
            "marriage", "divorce", "annulment", "engagement",
            "marriage_banns", "marriage_contract", "marriage_licence", "marriage_settlement",
            "divorce_filing",
            "custom"
          ]
        },
        "type_label": { "type": "string", "description": "Human label when type is 'custom'" },
        "date":        { "type": "string" },
        "place":       { "type": "string" },
        "coords":      { "$ref": "#/$defs/coords" },
        "age":         { "type": "string", "description": "Age of the person at the time of the event" },
        "cause":       { "type": "string", "description": "Cause of the event (e.g. cause of death)" },
        "agency":      { "type": "string", "description": "Responsible agency or organization" },
        "religion":    { "type": "string", "description": "Religious affiliation of the event" },
        "restriction": { "type": "string", "enum": ["confidential", "locked", "privacy"] },
        "note":        { "type": "string" },
        "sources":     { "$ref": "#/$defs/sources" }
      },
      "additionalProperties": false
    },

    "events": {
      "type": "array",
      "items": { "$ref": "#/$defs/event" }
    },

    "lifeEvent": {
      "type": ["object", "null"],
      "properties": {
        "date":        { "type": "string" },
        "place":       { "type": "string" },
        "coords":      { "$ref": "#/$defs/coords" },
        "age":         { "type": "string" },
        "cause":       { "type": "string", "description": "Cause (most relevant for death)" },
        "agency":      { "type": "string" },
        "restriction": { "type": "string", "enum": ["confidential", "locked", "privacy"] },
        "note":        { "type": "string" },
        "sources":     { "$ref": "#/$defs/sources" }
      },
      "additionalProperties": false
    },

    "coords": {
      "type": "object",
      "required": ["lat", "lng"],
      "properties": {
        "lat": { "type": "number" },
        "lng": { "type": "number" }
      },
      "additionalProperties": false
    }
  }
}
