{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "relation.schema.json",
  "type": "object",
  "required": ["uuid", "familytree_version", "type"],
  "properties": {
    "uuid":               { "type": "string", "format": "uuid" },
    "familytree_version": { "type": "string", "description": "FamilyTree spec version this file was written against (semver, e.g. '0.0.1')" },
    "media_files": {
      "description": "Media files related to this relation.",
      "type": "array",
      "items": { "$ref": "#/$defs/mediaFile" }
    },
    "notes":       { "type": "array", "items": { "type": "string" } },
    "uncertain":   { "type": "array", "items": { "type": "string" } },
    "restriction": { "type": "string", "enum": ["confidential", "locked", "privacy"] },
    "created":     { "type": "string", "description": "ISO 8601 datetime when this record was first created" },
    "changed":     { "type": "string", "description": "ISO 8601 datetime of last change" },
    "sources":     { "$ref": "#/$defs/sources" },
    "events":      { "$ref": "#/$defs/events" }
  },

  "oneOf": [
    {
      "properties": {
        "type":     { "const": "filiation" },
        "parent":   { "type": "string", "format": "uuid" },
        "child":    { "type": "string", "format": "uuid" },
        "pedigree": {
          "type": "string",
          "enum": ["birth", "adopted", "foster", "sealing", "donor", "surrogate", "guardian", "registered", "step"],
          "description": "Nature of the parent-child link (GEDCOM PEDI)"
        },
        "legal": {
          "type": "boolean",
          "description": "Whether this parent is legally recognised (e.g. on birth certificate). Omit when not relevant."
        },
        "end_date": {
          "type": "string",
          "description": "Date the relationship ended — for dissolved foster placements, revoked adoptions, etc."
        },
        "status": {
          "type": "string",
          "enum": ["challenged", "disproven", "proven"],
          "description": "Certainty of the linkage"
        }
      },
      "required": ["parent", "child"]
    },
    {
      "properties": {
        "type": { "const": "partner" },
        "persons": {
          "type": "array",
          "items": { "type": "string", "format": "uuid" },
          "minItems": 2,
          "maxItems": 2
        },
        "kind": {
          "type": "string",
          "enum": ["marriage", "civil_union", "cohabitation", "engagement", "custom"],
          "description": "Classification of the partnership"
        },
        "kind_label": {
          "type": "string",
          "description": "Human label when kind is 'custom'"
        },
        "end_date": {
          "type": ["string", "null"],
          "description": "Date the partnership ended — divorce, separation, dissolution, etc. Null means ongoing."
        }
      },
      "required": ["persons"]
    },
    {
      "description": "A non-family social or professional link between two persons (godfather, witness, employer, etc.). Guardianship belongs in filiation with pedigree 'guardian', not here.",
      "properties": {
        "type":     { "const": "association" },
        "from":     { "type": "string", "format": "uuid", "description": "The person the relation originates from" },
        "to":       { "type": "string", "format": "uuid", "description": "The person the relation points to" },
        "relation": { "type": "string", "description": "Nature of the link, e.g. godfather, witness, employer" }
      },
      "required": ["from", "to", "relation"]
    }
  ],

  "$defs": {
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title":         { "type": "string" },
          "type":          { "type": "string", "enum": ["personal-document","photograph","civil-record","church-record","census","oral","gedcom","other"] },
          "file":          { "type": "string" },
          "date":          { "type": "string" },
          "recorded_date": { "type": "string" },
          "page":          { "type": "string" },
          "text":          { "type": "string" },
          "quality":       { "type": "integer", "minimum": 0, "maximum": 3 },
          "event_type":    { "type": "string" },
          "role":          { "type": "string" },
          "note":          { "type": "string" }
        },
        "additionalProperties": false
      }
    },

    "event": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "marriage", "divorce", "annulment", "engagement",
            "marriage_banns", "marriage_contract", "marriage_licence", "marriage_settlement",
            "divorce_filing", "census", "residence", "custom"
          ]
        },
        "type_label":     { "type": "string", "description": "Human label when type is 'custom'" },
        "date":           { "type": "string" },
        "date_qualifier": { "$ref": "#/$defs/dateQualifier" },
        "date_to":        { "type": "string", "description": "End date for BET (between) qualifier" },
        "place":       { "type": "string" },
        "coords": {
          "type": "object",
          "required": ["lat", "lng"],
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          },
          "additionalProperties": false
        },
        "age_partner_a": { "type": "string", "description": "Age of first partner at event (GEDCOM HUSB/AGE)" },
        "age_partner_b": { "type": "string", "description": "Age of second partner at event (GEDCOM WIFE/AGE)" },
        "cause":         { "type": "string" },
        "agency":        { "type": "string" },
        "religion":      { "type": "string" },
        "restriction":   { "type": "string", "enum": ["confidential", "locked", "privacy"] },
        "note":          { "type": "string" },
        "sources":       { "$ref": "#/$defs/sources" }
      },
      "additionalProperties": false
    },

    "events": {
      "type": "array",
      "items": { "$ref": "#/$defs/event" }
    },

    "dateQualifier": {
      "type": "string",
      "enum": ["ABT", "BEF", "AFT", "BET", "CAL", "EST"],
      "description": "Date qualifier: ABT=about, BEF=before, AFT=after, BET=between (use date_to for end), CAL=calculated, EST=estimated"
    },

    "mediaFile": {
      "type": "object",
      "required": ["file"],
      "properties": {
        "file":    { "type": "string", "description": "Relative path (from the record's folder), absolute path, or URI" },
        "title":   { "type": "string", "description": "Human-readable title or caption" },
        "type":    { "type": "string", "enum": ["photo", "document", "certificate", "audio", "video", "other"], "description": "Type of media" },
        "date":    { "type": "string", "description": "Date of the media (e.g. when a photo was taken)" },
        "primary": { "type": "boolean", "description": "Whether this is the primary image for the record" },
        "note":    { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
