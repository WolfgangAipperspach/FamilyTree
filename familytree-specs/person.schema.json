{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "person.schema.json",
  "type": "object",
  "required": ["uuid", "familytree_version", "name"],
  "properties": {
    "uuid":               { "type": "string", "format": "uuid" },
    "familytree_version": { "type": "string", "description": "FamilyTree spec version this file was written against (semver, e.g. '0.0.1')" },

    "name": { "$ref": "#/$defs/nameObject" },
    "names": {
      "description": "Additional or alternate name variants (maiden, immigrant, alias, etc.)",
      "type": "array",
      "items": { "$ref": "#/$defs/nameObject" }
    },

    "sex":    { "type": "string", "enum": ["M", "F", "X"] },
    "gender": { "type": "string", "description": "Gender identity, when distinct from biological sex. Free text (e.g. 'male', 'female', 'non-binary', 'transgender woman')." },
    "title":  { "type": ["string", "null"], "description": "Nobility or honorific title (e.g. Sir, Dame, Duke)" },

    "birth":  { "$ref": "#/$defs/lifeEvent" },
    "death":  { "$ref": "#/$defs/lifeEvent" },
    "burial": { "$ref": "#/$defs/lifeEvent" },

    "occupation":           { "type": "array", "items": { "type": "string" } },
    "nationality":          { "type": "string" },
    "religion":             { "type": "string" },
    "caste":                { "type": "string" },
    "physical_description": { "type": "string" },
    "national_ids": {
      "description": "National or government-issued identifiers (passport, SSN, NHS number, etc.)",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["value"],
        "properties": {
          "value": { "type": "string" },
          "type":  { "type": "string", "description": "e.g. passport, ssn, nino, bsn" }
        },
        "additionalProperties": false
      }
    },
    "facts": {
      "description": "Typed personal facts or characteristics (GEDCOM FACT/EVEN with TYPE)",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "value"],
        "properties": {
          "type":  { "type": "string" },
          "value": { "type": "string" },
          "note":  { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "biography": { "type": "string", "description": "Free-text biographical narrative about the person's life." },

    "dna": {
      "description": "DNA test results and genetic data",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["provider"],
        "properties": {
          "provider":     { "type": "string", "description": "Test provider, e.g. 'AncestryDNA', '23andMe', 'FamilyTreeDNA'" },
          "kit_number":   { "type": "string", "description": "Kit or sample number" },
          "haplogroup_y": { "type": "string", "description": "Y-chromosome haplogroup (paternal line)" },
          "haplogroup_mt":{ "type": "string", "description": "Mitochondrial haplogroup (maternal line)" },
          "date":         { "type": "string", "description": "Date the test was taken or results received" },
          "note":         { "type": "string" }
        },
        "additionalProperties": false
      }
    },

    "living": { "type": "boolean", "description": "Whether the person is believed to be still alive. Tooling may use this to apply privacy rules automatically." },

    "external_refs": {
      "description": "Links to external profiles or records (Find A Grave, WikiTree, Ancestry, etc.)",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["url"],
        "properties": {
          "url":   { "type": "string", "description": "URL to the external profile or record" },
          "label": { "type": "string", "description": "Human-readable label, e.g. 'Find A Grave', 'WikiTree'" },
          "type":  { "type": "string", "description": "Machine-readable type, e.g. 'findagrave', 'wikitree', 'ancestry', 'familysearch'" },
          "note":  { "type": "string" }
        },
        "additionalProperties": false
      }
    },

    "avatar_file": { "type": ["string", "null"], "description": "Relative path (from the person's folder), absolute path, or URI to the person's avatar image. Null if not set." },
    "media_files": {
      "description": "Media files related to this person.",
      "type": "array",
      "items": { "$ref": "#/$defs/mediaFile" }
    },
    "notes":       { "type": "array", "items": { "type": "string" } },
    "sources":     { "$ref": "#/$defs/sources" },
    "events":      { "$ref": "#/$defs/events" },
    "uncertain":   { "type": "array", "items": { "type": "string" } },
    "restriction": { "type": "string", "enum": ["confidential", "locked", "privacy"] },
    "recorded_by": { "type": "string", "description": "Name or identifier of the researcher who created or last modified this record" },
    "created":     { "type": "string", "description": "ISO 8601 datetime when this record was first created" },
    "changed":     { "type": "string", "description": "ISO 8601 datetime of last change" }
  },
  "additionalProperties": false,

  "$defs": {
    "nameObject": {
      "type": "object",
      "properties": {
        "given":          { "type": "string", "description": "Given name(s)" },
        "surname":        { "type": "string", "description": "Surname(s)" },
        "surname_prefix": { "type": "string", "description": "Surname prefix (van, de, von)" },
        "prefix":         { "type": "string", "description": "Name prefix (Dr., Rev., Sir)" },
        "suffix":         { "type": "string", "description": "Name suffix (Jr., III, Esq.)" },
        "nickname":       { "type": "string", "description": "Nickname, distinct from alias" },
        "alias":          { "type": "string", "description": "Known alias or stage name" },
        "type":           { "type": "string", "description": "Name type: birth, maiden, immigrant, adopted, alias, etc." },
        "phonetic":       { "type": "string", "description": "Phonetic variation of the full name" },
        "romanized":      { "type": "string", "description": "Romanized variation of the full name" },
        "note":           { "type": "string" }
      },
      "additionalProperties": false
    },

    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title":         { "type": "string", "description": "Short description of the source" },
          "type":          { "type": "string", "enum": ["personal-document","photograph","civil-record","church-record","census","oral","gedcom","other"] },
          "file":          { "type": "string", "description": "Path or URL to the source file" },
          "date":          { "type": "string", "description": "Date the source was created or accessed" },
          "recorded_date": { "type": "string", "description": "Date the entry was recorded in the source" },
          "page":          { "type": "string", "description": "Page, folio, or frame reference within the source" },
          "text":          { "type": "string", "description": "Verbatim transcription of relevant text" },
          "quality":       { "type": "integer", "minimum": 0, "maximum": 3, "description": "Certainty: 0 unreliable, 1 questionable, 2 secondary, 3 primary" },
          "event_type":    { "type": "string", "description": "Type of event recorded in this source" },
          "role":          { "type": "string", "description": "Person's role in the cited event (e.g. bride, witness)" },
          "recorded_by":   { "type": "string", "description": "Researcher who cited or transcribed this source" },
          "note":          { "type": "string" }
        },
        "additionalProperties": false
      }
    },

    "event": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "immigration", "emigration", "residence", "military", "census", "education",
            "christening", "cremation", "adoption", "baptism", "bar_mitzvah", "bat_mitzvah",
            "blessing", "adult_christening", "confirmation", "first_communion", "ordination",
            "naturalization", "probate", "will", "graduation", "retirement",
            "marriage", "divorce", "annulment", "engagement",
            "marriage_banns", "marriage_contract", "marriage_licence", "marriage_settlement",
            "divorce_filing",
            "custom"
          ]
        },
        "type_label":       { "type": "string", "description": "Human label when type is 'custom'" },
        "date":             { "type": "string" },
        "date_qualifier":   { "$ref": "#/$defs/dateQualifier" },
        "date_to":          { "type": "string", "description": "End date for BET (between) qualifier" },
        "place":            { "type": "string" },
        "coords":      { "$ref": "#/$defs/coords" },
        "age":         { "type": "string", "description": "Age of the person at the time of the event" },
        "cause":       { "type": "string", "description": "Cause of the event (e.g. cause of death)" },
        "agency":      { "type": "string", "description": "Responsible agency or organization" },
        "religion":    { "type": "string", "description": "Religious affiliation of the event" },
        "restriction":  { "type": "string", "enum": ["confidential", "locked", "privacy"] },
        "recorded_by":  { "type": "string", "description": "Researcher who recorded this event" },
        "note":         { "type": "string" },
        "sources":      { "$ref": "#/$defs/sources" }
      },
      "additionalProperties": false
    },

    "events": {
      "type": "array",
      "items": { "$ref": "#/$defs/event" }
    },

    "lifeEvent": {
      "type": ["object", "null"],
      "properties": {
        "date":           { "type": "string" },
        "date_qualifier": { "$ref": "#/$defs/dateQualifier" },
        "date_to":        { "type": "string", "description": "End date for BET (between) qualifier" },
        "place":          { "type": "string" },
        "coords":      { "$ref": "#/$defs/coords" },
        "age":         { "type": "string" },
        "cause":       { "type": "string", "description": "Cause (most relevant for death)" },
        "agency":      { "type": "string" },
        "restriction":  { "type": "string", "enum": ["confidential", "locked", "privacy"] },
        "recorded_by":  { "type": "string", "description": "Researcher who recorded this event" },
        "note":         { "type": "string" },
        "sources":      { "$ref": "#/$defs/sources" }
      },
      "additionalProperties": false
    },

    "dateQualifier": {
      "type": "string",
      "enum": ["ABT", "BEF", "AFT", "BET", "CAL", "EST"],
      "description": "Date qualifier: ABT=about, BEF=before, AFT=after, BET=between (use date_to for end), CAL=calculated, EST=estimated"
    },

    "mediaFile": {
      "type": "object",
      "required": ["file"],
      "properties": {
        "file":    { "type": "string", "description": "Relative path (from the record's folder), absolute path, or URI" },
        "title":   { "type": "string", "description": "Human-readable title or caption" },
        "type":    { "type": "string", "enum": ["photo", "document", "certificate", "audio", "video", "other"], "description": "Type of media" },
        "date":    { "type": "string", "description": "Date of the media (e.g. when a photo was taken)" },
        "primary": { "type": "boolean", "description": "Whether this is the primary image for the record" },
        "note":    { "type": "string" }
      },
      "additionalProperties": false
    },

    "coords": {
      "type": "object",
      "required": ["lat", "lng"],
      "properties": {
        "lat": { "type": "number" },
        "lng": { "type": "number" }
      },
      "additionalProperties": false
    }
  }
}
